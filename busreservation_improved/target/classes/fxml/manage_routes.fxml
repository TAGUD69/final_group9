<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.busreservation.controllers.ManageRoutesController" spacing="15">
    
    <Label text="Manage Routes" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
    
    <HBox spacing="10">
        <ComboBox fx:id="originCombo" promptText="Origin" editable="true" prefWidth="120"/>
        <ComboBox fx:id="destinationCombo" promptText="Destination" editable="true" prefWidth="120"/>
        <TextField fx:id="distanceField" promptText="Distance (km)" prefWidth="100"/>
        <TextField fx:id="fareField" promptText="Fare (₱)" prefWidth="100"/>
        <Button text="Add" onAction="#handleAdd" style="-fx-background-color: #27ae60; -fx-text-fill: white;"/>
        <Button text="Update" onAction="#handleUpdate" style="-fx-background-color: #3498db; -fx-text-fill: white;"/>
        <Button text="Delete" onAction="#handleDelete" style="-fx-background-color: #e74c3c; -fx-text-fill: white;"/>
        <Button text="Clear" onAction="#handleClear"/>
    </HBox>
    
    <TableView fx:id="routesTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn text="ID" fx:id="colId" prefWidth="50"/>
            <TableColumn text="Origin" fx:id="colOrigin" prefWidth="150"/>
            <TableColumn text="Destination" fx:id="colDestination" prefWidth="150"/>
            <TableColumn text="Distance (km)" fx:id="colDistance" prefWidth="100"/>
            <TableColumn text="Base Fare (₱)" fx:id="colFare" prefWidth="100"/>
        </columns>
    </TableView>
</VBox>