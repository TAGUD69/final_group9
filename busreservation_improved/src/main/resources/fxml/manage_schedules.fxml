<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.busreservation.controllers.ManageSchedulesController"
      spacing="15" style="-fx-background-color: white; -fx-padding: 20;">

    <Label text="⚙ Manage Schedules"
           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

    <GridPane hgap="15" vgap="10"
              style="-fx-background-color: #f8f9fa; -fx-padding: 15; -fx-background-radius: 8;
                     -fx-border-color: #e0e0e0; -fx-border-radius: 8;">

        <Label text="Bus:"       style="-fx-font-weight: bold;" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <ComboBox fx:id="busCombo" promptText="Select bus" prefWidth="200"
                  GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Route:"     style="-fx-font-weight: bold;" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <ComboBox fx:id="routeCombo" promptText="Select route" prefWidth="200"
                  GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Departure:" style="-fx-font-weight: bold;" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <HBox spacing="6" GridPane.rowIndex="2" GridPane.columnIndex="1" alignment="CENTER_LEFT">
            <DatePicker fx:id="departureDate" prefWidth="135"/>
            <ComboBox fx:id="departureHour"   promptText="HH" prefWidth="65"/>
            <Label text=":"/>
            <ComboBox fx:id="departureMinute" promptText="MM" prefWidth="65"/>
        </HBox>

        <Label text="Arrival:"   style="-fx-font-weight: bold;" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <HBox spacing="6" GridPane.rowIndex="3" GridPane.columnIndex="1" alignment="CENTER_LEFT">
            <DatePicker fx:id="arrivalDate" prefWidth="135"/>
            <ComboBox fx:id="arrivalHour"   promptText="HH" prefWidth="65"/>
            <Label text=":"/>
            <ComboBox fx:id="arrivalMinute" promptText="MM" prefWidth="65"/>
        </HBox>

        <Label text="Seats:"       style="-fx-font-weight: bold;" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
        <TextField fx:id="seatsField" promptText="e.g. 45"
                   GridPane.rowIndex="4" GridPane.columnIndex="1" prefWidth="100"
                   style="-fx-padding: 6; -fx-border-color: #bdc3c7; -fx-border-radius: 5;"/>

        <Label text="Fare ×:"      style="-fx-font-weight: bold;" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
        <TextField fx:id="multiplierField" promptText="1.0"
                   GridPane.rowIndex="5" GridPane.columnIndex="1" prefWidth="100"
                   style="-fx-padding: 6; -fx-border-color: #bdc3c7; -fx-border-radius: 5;"/>

        <HBox spacing="10" GridPane.rowIndex="6" GridPane.columnSpan="2" GridPane.columnIndex="0">
            <Button text="➕ Add Schedule" onAction="#handleAdd"
                    style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-background-radius: 20;
                           -fx-cursor: hand; -fx-padding: 8 20; -fx-font-weight: bold;"/>
            <Button text="🗑 Delete Selected" onAction="#handleDelete"
                    style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-background-radius: 20;
                           -fx-cursor: hand; -fx-padding: 8 20; -fx-font-weight: bold;"/>
            <Button text="Clear" onAction="#handleClear"
                    style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-background-radius: 20;
                           -fx-cursor: hand; -fx-padding: 8 20;"/>
        </HBox>
    </GridPane>

    <TableView fx:id="schedulesTable" VBox.vgrow="ALWAYS"
               style="-fx-border-color: #e0e0e0; -fx-border-radius: 8;">
        <columns>
            <TableColumn text="ID"        fx:id="colId"        prefWidth="55"/>
            <TableColumn text="Bus"       fx:id="colBus"       prefWidth="180"/>
            <TableColumn text="Route"     fx:id="colRoute"     prefWidth="200"/>
            <TableColumn text="Departure" fx:id="colDeparture" prefWidth="150"/>
            <TableColumn text="Arrival"   fx:id="colArrival"   prefWidth="150"/>
            <TableColumn text="Seats"     fx:id="colSeats"     prefWidth="70"/>
        </columns>
    </TableView>
</VBox>
