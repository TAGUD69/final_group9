<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.busreservation.controllers.SignUpController" style="-fx-background-color: white;" spacing="15">
    
    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>
    
    <Label text="Create New Account" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1a2980;" alignment="CENTER"/>
    <Label text="Please fill in your details" style="-fx-text-fill: gray;" alignment="CENTER"/>
    
    <Separator/>
    
    <GridPane hgap="15" vgap="15">
        <Label text="Full Name:" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <TextField fx:id="fullNameField" promptText="Enter your full name" prefWidth="250" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
        
        <Label text="Username:" GridPane.rowIndex="1" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <TextField fx:id="usernameField" promptText="Choose a username" prefWidth="250" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
        
        <Label text="Password:" GridPane.rowIndex="2" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <PasswordField fx:id="passwordField" promptText="Choose a password" prefWidth="250" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
        
        <Label text="Confirm Password:" GridPane.rowIndex="3" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <PasswordField fx:id="confirmPasswordField" promptText="Confirm your password" prefWidth="250" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
    </GridPane>
    
    <HBox spacing="15" alignment="CENTER">
        <Button text="Sign Up" onAction="#handleSignUp" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-padding: 10 30 10 30; -fx-background-radius: 25; -fx-cursor: hand;"/>
        <Button text="Cancel" onAction="#handleCancel" style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-padding: 10 30 10 30; -fx-background-radius: 25; -fx-cursor: hand;"/>
    </HBox>
</VBox>