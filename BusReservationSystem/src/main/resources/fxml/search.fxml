<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.busreservation.controllers.SearchController" spacing="15" style="-fx-padding: 20; -fx-background-color: white;">
    
    <!-- Welcome Banner -->
    <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: linear-gradient(to right, #e8f4f8, white); -fx-padding: 15; -fx-background-radius: 10;">
        <Label text="🚌" style="-fx-font-size: 36px;"/>
        <VBox>
            <Label text="Plan Your Trip" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
            <Label text="Find and book buses across Davao del Sur" style="-fx-font-size: 12px; -fx-text-fill: #7f8c8d;"/>
        </VBox>
    </HBox>
    
    <!-- Search Card -->
    <GridPane style="-fx-background-color: white; -fx-background-radius: 10; -fx-border-color: #e0e0e0; -fx-border-radius: 10; -fx-border-width: 1; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 2);" hgap="15" vgap="12" VBox.vgrow="NEVER">
        
        <Label text="From:" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
        <ComboBox fx:id="fromCombo" promptText="Select origin" prefWidth="180" GridPane.rowIndex="0" GridPane.columnIndex="1" style="-fx-background-radius: 5; -fx-padding: 5;"/>
        
        <Label text="To:" GridPane.rowIndex="0" GridPane.columnIndex="2" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
        <ComboBox fx:id="toCombo" promptText="Select destination" prefWidth="180" GridPane.rowIndex="0" GridPane.columnIndex="3" style="-fx-background-radius: 5; -fx-padding: 5;"/>
        
        <Label text="Travel Date:" GridPane.rowIndex="1" GridPane.columnIndex="0" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
        <DatePicker fx:id="datePicker" prefWidth="180" GridPane.rowIndex="1" GridPane.columnIndex="1" style="-fx-background-radius: 5;"/>
        
        <Label text="Bus Type:" GridPane.rowIndex="1" GridPane.columnIndex="2" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
        <ComboBox fx:id="busTypeFilter" promptText="All Types" prefWidth="180" GridPane.rowIndex="1" GridPane.columnIndex="3" style="-fx-background-radius: 5; -fx-padding: 5;"/>
        
        <Button text="🔍 Find Buses" onAction="#handleSearch" GridPane.rowIndex="0" GridPane.columnIndex="4" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-background-radius: 25; -fx-padding: 8 30 8 30; -fx-cursor: hand; -fx-font-weight: bold; -fx-effect: dropshadow(gaussian, rgba(52,152,219,0.3), 5, 0, 0, 2);"/>
        <Button text="📍 Today's Buses" onAction="#showTodayBuses" GridPane.rowIndex="1" GridPane.columnIndex="4" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-background-radius: 25; -fx-padding: 8 30 8 30; -fx-cursor: hand; -fx-font-weight: bold; -fx-effect: dropshadow(gaussian, rgba(39,174,96,0.3), 5, 0, 0, 2);"/>
        
    </GridPane>
    
    <!-- Results Header -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label fx:id="resultCountLabel" text="Showing 0 buses" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Reset All" onAction="#resetSearch" style="-fx-background-color: transparent; -fx-text-fill: #e74c3c; -fx-underline: true; -fx-cursor: hand; -fx-padding: 5 10 5 10;"/>
        <Label text="Last updated:" style="-fx-font-size: 11px; -fx-text-fill: #95a5a6;"/>
        <Label fx:id="lastUpdatedLabel" style="-fx-font-size: 11px; -fx-text-fill: #95a5a6; -fx-font-weight: bold;"/>
    </HBox>
    
    <!-- Buses Table -->
    <TableView fx:id="resultsTable" VBox.vgrow="ALWAYS" style="-fx-background-radius: 10; -fx-border-color: #e0e0e0; -fx-border-radius: 10;">
        <columns>
            <TableColumn text="Bus No" fx:id="colBusNumber" prefWidth="90"/>
            <TableColumn text="Bus Name" fx:id="colBusName" prefWidth="180"/>
            <TableColumn text="Type" fx:id="colBusType" prefWidth="70"/>
            <TableColumn text="From" fx:id="colOrigin" prefWidth="120"/>
            <TableColumn text="To" fx:id="colDestination" prefWidth="120"/>
            <TableColumn text="Departure" fx:id="colDeparture" prefWidth="140"/>
            <TableColumn text="Arrival" fx:id="colArrival" prefWidth="140"/>
            <TableColumn text="Duration" fx:id="colDuration" prefWidth="80"/>
            <TableColumn text="Seats" fx:id="colAvailableSeats" prefWidth="70"/>
            <TableColumn text="Fare" fx:id="colFare" prefWidth="80"/>
            <TableColumn text="" fx:id="colAction" prefWidth="70"/>
        </columns>
    </TableView>
    
    <ProgressIndicator fx:id="loadingIndicator" visible="false" maxWidth="40" maxHeight="40" managed="false"/>
</VBox>