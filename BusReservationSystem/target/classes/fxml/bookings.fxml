<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.busreservation.controllers.MyBookingsController" spacing="15">
    
    <Label text="My Bookings" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
    
    <TableView fx:id="bookingsTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn text="ID" fx:id="colBookingId" prefWidth="60"/>
            <TableColumn text="Date" fx:id="colDate" prefWidth="150"/>
            <TableColumn text="Bus" fx:id="colBus" prefWidth="150"/>
            <TableColumn text="Route" fx:id="colRoute" prefWidth="200"/>
            <TableColumn text="Passenger" fx:id="colPassenger" prefWidth="120"/>
            <TableColumn text="Seats" fx:id="colSeats" prefWidth="80"/>
            <TableColumn text="Fare" fx:id="colFare" prefWidth="80"/>
            <TableColumn text="Status" fx:id="colStatus" prefWidth="80"/>
            <TableColumn text="" fx:id="colAction" prefWidth="70"/>
        </columns>
    </TableView>
</VBox>